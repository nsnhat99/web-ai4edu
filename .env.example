POSTGRES_URL=
BLOB_READ_WRITE_TOKEN=

# Google Sheets + Drive (public form submissions)
# Base64-encoded service account JSON key. Generate with:
#   base64 -w 0 service-account.json > key.b64
GOOGLE_SERVICE_ACCOUNT_JSON=
# ID of the Google Spreadsheet (must contain tabs: Papers, Registrations, Contacts)
GOOGLE_SHEET_ID=
# ID of the Drive folder (must be inside a Shared Drive; share with service account email as Content Manager)
GOOGLE_DRIVE_FOLDER_ID=
